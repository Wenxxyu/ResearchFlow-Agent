#Time out
RESEARCHFLOW_LLM_TIMEOUT_SECONDS=30
RESEARCHFLOW_EMBEDDING_TIMEOUT_SECONDS=60
RESEARCHFLOW_RERANKER_TIMEOUT_SECONDS=30


# Core storage
RESEARCHFLOW_DATABASE_URL=sqlite:///./data/researchflow.sqlite3
RESEARCHFLOW_UPLOAD_DIR=data/uploads
RESEARCHFLOW_REPO_DIR=data/repos
RESEARCHFLOW_SKILL_DIR=skills

# LLM provider: mock | openai | openai_compatible | qwen | deepseek
RESEARCHFLOW_LLM_PROVIDER=mock
RESEARCHFLOW_LLM_API_KEY=
RESEARCHFLOW_LLM_BASE_URL=
RESEARCHFLOW_LLM_MODEL=gpt-4.1-mini
RESEARCHFLOW_LLM_TIMEOUT_SECONDS=30

# Embedding provider: mock | openai | openai_compatible | qwen
RESEARCHFLOW_EMBEDDING_PROVIDER=mock
RESEARCHFLOW_EMBEDDING_API_KEY=
RESEARCHFLOW_EMBEDDING_BASE_URL=
RESEARCHFLOW_EMBEDDING_MODEL=text-embedding-3-small
RESEARCHFLOW_EMBEDDING_DIMENSION=1536
RESEARCHFLOW_EMBEDDING_TIMEOUT_SECONDS=60

# Reranker provider: noop | openai | openai_compatible | qwen | deepseek
# The OpenAI-compatible reranker asks a chat model to reorder the top candidate chunks.
RESEARCHFLOW_RERANKER_PROVIDER=noop
RESEARCHFLOW_RERANKER_API_KEY=
RESEARCHFLOW_RERANKER_BASE_URL=
RESEARCHFLOW_RERANKER_MODEL=gpt-4.1-mini
RESEARCHFLOW_RERANKER_TIMEOUT_SECONDS=30
